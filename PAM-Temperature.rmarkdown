# Analysis


Table 1. The mean, standard deviation (Std. Dev.), and standard error (Std. Err.) of the effective quantum yield (&Delta;Fv/Fm&prime;).

```{r}
data |> 
  group_by(Days, Temp) |> 
  reframe(across(value, list(m = mean, sd = sd, se = se, n = length))) |> 
  mutate(Days = str_glue("{Days}-d ")) |> 
  gt() |> 
  cols_label(
    Days = "Incubation duration (Days)",
    Temp = "Temperature (&deg;C)",
    value_m = "Mean",
    value_m = "Mean",
    value_sd = "Std. Dev.",
    value_se = "Std. Error",
    value_n = "N"
  ) |> 
  fmt_number(columns = c(value_m, value_sd), decimals = 3) |> 
  fmt_number(columns = value_se, decimals = 3) |> 
  tab_style(
    style = list(cell_fill(color = "grey90")),
    locations = cells_body(rows = str_detect(Days, "3|7"))
  ) |> 
  tab_source_note(
    source_note = md("12L12D, 50 PAR (&mu;mol photons m<sup>-2</sup> s<sup>-1</sup>)")
  )
```


```{r}
data = data |> mutate(Days = factor(Days), fTemp = factor(Temp))
# Functions ####################################################################
fad = function(h, x, xopt) {
  gas_constant = 8.314 / 1000.0;
  y = h * (x - xopt) / (x * gas_constant * xopt)
  exp(y)
}

ptmodel = function(x, xopt, yopt, eta, ha) {
  x = x + 273.15; 
  xopt = xopt + 273.15
  hd = ha * eta
  fa = fad(ha, x, xopt)
  fd = fad(hd, x, xopt)
  (yopt * eta * fa) / (eta + fd - 1)
}
# Fit the brms model ###########################################################
stan_ptfunction = 
  "
real ptmodel(real xopt, real yopt, real ha, real eta, real temperature) {
  real x = temperature + 273.15;
  real hd = ha * eta;
  real gasConstant = 8.314 / 1000.0;
  real fa = exp(ha * (x - xopt) / (x * gasConstant * xopt));
  real fd = exp(hd * (x - xopt) / (x * gasConstant * xopt));
  return yopt * eta * fa / (eta - 1 + fd);
}
"

stanvars = stanvar(scode = stan_ptfunction, block = "functions")
fullmodel = 
  bf(value ~ ptmodel(KT, PM, HA, ET, Temp),
     PM + HA + ET + KT ~ 1,
     nl = TRUE) + 
  xbeta(link = "identity")

get_prior(fullmodel, data = data)
# get_prior(nullmodel, data = data)

priors = c(
  prior(student_t(3, 40, 2.5),   class = b, nlpar = ET,  lb = 2),
  prior(student_t(3, 10, 2.5),   class = b, nlpar = HA,  lb = 0),
  prior(student_t(3, 300, 2.5),  class = b, nlpar = KT,  lb = 273),
  prior(student_t(3, 0.5, 1),    class = b, nlpar = PM,  lb = 0),
  prior(gamma(0.01, 0.01), class = kappa),
  prior(gamma(0.01, 0.01), class = phi)
)


```


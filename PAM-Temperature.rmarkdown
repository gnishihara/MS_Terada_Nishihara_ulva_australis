```{r}
fitmodel = function(data, Days) {
  stan_ptfunction = 
    "
    real ptmodel(real xopt, real yopt, real ha, real eta, real temperature) {
      real x = temperature + 273.15;
      real hd = ha * eta;
      real gasConstant = 8.314 / 1000.0;
      real fa = exp(ha * (x - xopt) / (x * gasConstant * xopt));
      real fd = exp(hd * (x - xopt) / (x * gasConstant * xopt));
      return yopt * eta * fa / (eta - 1 + fd);
    }
    "
  
  stanvars = stanvar(scode = stan_ptfunction, block = "functions")
  fullmodel = 
    bf(value ~ ptmodel(KT, PM, HA, ET, Temp),
       PM + HA + ET + KT ~ 1,
       kappa ~ (0+1|fTemp),
       nl = TRUE) + 
    xbeta(link = "identity")
  
  priors = c(
    prior(student_t(3, 40, 2.5),   class = b, nlpar = ET,  lb = 2),
    prior(student_t(3, 10, 2.5),   class = b, nlpar = HA,  lb = 0),
    prior(student_t(3, 300, 2.5),  class = b, nlpar = KT,  lb = 273),
    prior(student_t(3, 0.5, 1),    class = b, nlpar = PM,  lb = 0),
    prior(student_t(3, 0, 2.5), class = sd, dpar = kappa),
    prior(gamma(0.01, 0.01), class = phi)
  )
  cores = chains = 5
  seed = 2026
  warmup = 4000/4
  iterations = warmup + 10000/4
  file_refit = "never"
  control = list(adapt_delta = 0.95, max_treedepth = 15)
  filename = str_glue("pam-ptcurve-{as.character(Days)}D-fullmodel")
  mout = brm(
    fullmodel,
    data = data,
    stanvars = stanvars,
    prior = priors,
    chains = chains,
    cores = cores,
    seed = seed,
    iter = iterations,
    warmup = warmup,
    refresh = 1000,
    file = filename,
    file_refit = file_refit,
    control = control,
    save_pars = save_pars(all = TRUE)
  )
  # mout = add_criterion(mout, criterion = c("loo", "waic"), seed = 2025, cores = cores)
  return(mout)
}

data = data |> 
  group_nest(Days) |>
  mutate(nullout = list(bout, bout, bout, bout)) |> 
  mutate(fullout = map2(data, Days, fitmodel))


```



